PORT=5000
NODE_ENV=development

# ── Supabase ───────────────────────────────────────
# Get these three values from: 
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # ← secret key, never share!

# ── JWT (your own tokens) ──────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-string-2025
JWT_EXPIRE=7d

# Gmail SMTP — use an App Password, not your real Gmail password
# Go to Google Account → Security → 2FA → App Passwords → generate one
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your mail
EMAIL_PASS= 16 character app password
EMAIL_FROM="Digital Wallet Demo <your mail>"

# Rate limiting (protect login/signup)
RATE_LIMIT_MAX=100