PORT=5000
NODE_ENV=development

# ── Supabase ───────────────────────────────────────
# Get these three values from: 
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # ← secret key, never share!

# ── JWT (your own tokens) ──────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-string-2025
JWT_EXPIRE=7d

# # ── Email (for OTP & password reset) ───────────────
# # Use Gmail + App Password: https://myaccount.google.com/apppasswords
# EMAIL_USER=yourname@gmail.com
# EMAIL_PASS=abcd-efgh-ijkl-mnop          # ← 16-char app password, NO normal password!

# Rate limiting (protect login/signup)
RATE_LIMIT_MAX=100